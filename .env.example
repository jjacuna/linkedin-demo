# Required — OpenRouter API key for Gemini 2.5 Flash (post + prompt generation)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Required — Kie.ai API key for Nano Banana image generation and Veo 3.1 video generation
KIE_API_KEY=your_kie_api_key_here

# Optional — defaults to 5001 locally, Railway sets this automatically
PORT=5001
